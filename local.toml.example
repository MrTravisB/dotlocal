# local.toml
#
# Machine-specific overrides. Copy to local.toml (gitignored).
#
# - Add entries: append new primitives of any type
# - Skip entries: use [[skip]] to exclude items from dotlocal.toml

# Skip a desktop app on this machine
# [[skip]]
# type = "app"
# name = "Docker Desktop"

# Skip a symlink
# [[skip]]
# type = "symlink"
# source = "terminal/ghostty/config"

# Add a machine-specific symlink
# [[symlink]]
# source = "shell/.zshrc.work"
# target = "~/.zshrc.work"
